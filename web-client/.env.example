# Base URL of the FastAPI backend (no trailing slash required).
# Used for POST /chat (companion agent), POST /transcribe (Sarvam STT), POST /tts (Sarvam TTS).
# Server must allow this origin in CORS_ORIGINS (see app/config.py). SARVAM_API_KEY must be set on the API for TTS/STT.
VITE_API_URL=http://127.0.0.1:8000
