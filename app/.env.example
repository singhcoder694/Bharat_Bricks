# Databricks AI Gateway
DATABRICKS_TOKEN=your-databricks-pat
DATABRICKS_BASE_URL=https://your-workspace-id.ai-gateway.cloud.databricks.com/mlflow/v1

# Models
LLM_MODEL=databricks-gpt-oss-20b
COMPANION_MODEL=databricks-meta-llama-3-3-70b-instruct
EMBEDDING_MODEL=databricks-bge-large-en

# Google Drive (for audit ingestion)
DRIVE_FOLDER_URL=https://drive.google.com/drive/folders/your-folder-id
GOOGLE_API_KEY=your-google-api-key

# Unity Catalog Volumes (optional, for audit ingestion from Databricks)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
UC_TOKEN=your-workspace-pat
UC_CATALOG=main
UC_SCHEMA=rag
UC_VOLUME=documents

# Sarvam AI (voice features — optional)
SARVAM_API_KEY=your-sarvam-api-key

# Databricks Vector Search (RAG)
VS_WORKSPACE_URL=https://your-vs-workspace.cloud.databricks.com
VS_TOKEN=your-vs-workspace-pat
VS_ENDPOINT=rag_endpoint
VS_INDEX=main.rag.docs_index
RAG_TOP_K=5

# CORS (comma-separated origins for browser clients)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
